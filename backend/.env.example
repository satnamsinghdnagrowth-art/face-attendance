NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/attendance_db
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
FRONTEND_URL=http://localhost:3000
FACE_SIMILARITY_THRESHOLD=0.75
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=your_32_char_encryption_key_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
LOG_LEVEL=info
LOG_DIR=./logs
